---
// Pill.astro
// Simple pill component for inline highlighting, e.g. percentages
// Usage: <Pill>10%</Pill>
---

<span
  class="inline-block rounded-full bg-gray-200 dark:bg-slate-700 px-3 py-1 font-bold text-gray-800 dark:text-gray-100 align-middle"
  style="vertical-align:middle; margin-right: 0.5em;"
>
  <slot />
</span>
