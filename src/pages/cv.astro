---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'CV',
};
---

<Layout metadata={metadata}>
  <section class="px-6 sm:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-4xl">
    <div class="text-center pb-10 md:pb-16 max-w-5xl mx-auto border-b border-gray-200 dark:border-slate-800">
      <h1 class="text-5xl md:text-6xl font-bold leading-tighter tracking-tighter mb-4 font-heading">
        Stepan Hilbert
      </h1>
      <p class="text-xl text-slate-600 dark:text-slate-300 font-light mb-6">
        Builder, co-founder & CTO. Passionate about products people actually love.
      </p>
      <div class="flex flex-wrap justify-center items-center gap-3 text-sm text-secondary dark:text-slate-400 font-medium">
        <span>Prague, Czechia</span>
        <span class="text-slate-300 dark:text-slate-600">&bull;</span>
        <a href="mailto:stepan@stehil.com" class="hover:text-primary dark:hover:text-blue-400 transition-colors">stepan@stehil.com</a>
        <span class="text-slate-300 dark:text-slate-600">&bull;</span>
        <a href="https://www.linkedin.com/in/stepanhilbert/" target="_blank" rel="noopener noreferrer" class="hover:text-primary dark:hover:text-blue-400 transition-colors">LinkedIn</a>
      </div>
    </div>

    <div class="mx-auto max-w-3xl mt-12 space-y-16">
      <!-- HIGHLIGHT -->
      <div>
        <h2 class="text-sm font-bold tracking-widest uppercase text-secondary dark:text-slate-500 mb-6 font-heading">Highlight</h2>
        <div class="prose prose-lg dark:prose-invert max-w-none text-slate-700 dark:text-slate-300">
          <p>
            Co-founded <a href="https://www.budgetly.com.au" target="_blank">Budgetly</a>, a B2B SaaS fintech, as a CTO and scaled it to hundreds of customers and A$100M+ in annual card spend - from scratch, self-funded.
          </p>
        </div>
      </div>

      <!-- MISSION -->
      <div>
        <h2 class="text-sm font-bold tracking-widest uppercase text-secondary dark:text-slate-500 mb-6 font-heading">Mission</h2>
        <div class="prose prose-lg dark:prose-invert max-w-none text-slate-700 dark:text-slate-300">
          <p>
            Seeking a high-impact role alongside a talented team, with a strong AI focus.
          </p>
        </div>
      </div>

      <!-- EXPERIENCE -->
      <div>
        <h2 class="text-sm font-bold tracking-widest uppercase text-secondary dark:text-slate-500 mb-6 font-heading">Experience</h2>
        <div class="space-y-10">
          
          <!-- Mapnook -->
          <div class="flex flex-col sm:flex-row gap-5">
            <div class="shrink-0 w-12 h-12 rounded-lg overflow-hidden bg-slate-100 dark:bg-slate-800 shadow-sm mt-1 border border-slate-200 dark:border-slate-700">
              <a href="https://mapnook.com" target="_blank" class="block w-full h-full hover:opacity-80 transition-opacity">
                <img src="/logos/mapnook.jpg" alt="Mapnook" class="w-full h-full object-cover" />
              </a>
            </div>
            <div class="flex-1">
              <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-y-2 mb-2">
                <div>
                  <h3 class="font-bold text-lg text-slate-900 dark:text-slate-100 leading-snug">Founder</h3>
                  <p class="text-secondary dark:text-slate-400 text-sm mt-0.5">
                    <a href="https://mapnook.com" target="_blank" class="hover:text-primary dark:hover:text-blue-400 transition-colors">Mapnook</a>
                  </p>
                </div>
                <div class="flex items-center gap-3">
                  <span class="text-[10px] font-bold uppercase tracking-wider bg-primary text-white dark:bg-blue-600 px-2.5 py-1 rounded-full">Now</span>
                  <span class="text-sm text-secondary dark:text-slate-400 whitespace-nowrap">Apr 2025 - Present</span>
                </div>
              </div>
              <p class="text-xs text-secondary dark:text-slate-500 mb-3 font-medium uppercase tracking-wide">Prague &bull; Remote</p>
              <div class="prose prose-md dark:prose-invert max-w-none text-slate-700 dark:text-slate-300">
                <p>Building the anti-TikTok for place discovery - an AI-powered app that finds inspiring local activities personalised to your interests, time of day, weather and season.</p>
              </div>
            </div>
          </div>

          <!-- Budgetly -->
          <div class="flex flex-col sm:flex-row gap-5">
            <div class="shrink-0 w-12 h-12 rounded-lg overflow-hidden bg-slate-100 dark:bg-slate-800 shadow-sm mt-1 border border-slate-200 dark:border-slate-700">
              <a href="https://www.budgetly.com.au" target="_blank" class="block w-full h-full hover:opacity-80 transition-opacity">
                <img src="/logos/budgetly.jpg" alt="Budgetly" class="w-full h-full object-cover" />
              </a>
            </div>
            <div class="flex-1">
              <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-y-2 mb-2">
                <div>
                  <h3 class="font-bold text-lg text-slate-900 dark:text-slate-100 leading-snug">CTO & Co-founder</h3>
                  <p class="text-secondary dark:text-slate-400 text-sm mt-0.5">
                    <a href="https://www.budgetly.com.au" target="_blank" class="hover:text-primary dark:hover:text-blue-400 transition-colors">Budgetly</a>
                  </p>
                </div>
                <div class="flex items-center gap-3">
                  <span class="text-sm text-secondary dark:text-slate-400 whitespace-nowrap">Mar 2019 - Dec 2023</span>
                </div>
              </div>
              <p class="text-xs text-secondary dark:text-slate-500 mb-3 font-medium uppercase tracking-wide">Australia &bull; Remote</p>
              <div class="prose prose-md dark:prose-invert max-w-none text-slate-700 dark:text-slate-300">
                <p>Took a B2B fintech from zero to A$100M+ annual card spend. Grew to hundreds of business customers with thousands of daily transactions - self-funded, small team.</p>
              </div>
            </div>
          </div>

          <!-- UENI Ltd -->
          <div class="flex flex-col sm:flex-row gap-5">
            <div class="shrink-0 w-12 h-12 rounded-lg overflow-hidden bg-slate-100 dark:bg-slate-800 shadow-sm mt-1 border border-slate-200 dark:border-slate-700">
              <a href="https://ueni.com" target="_blank" class="block w-full h-full hover:opacity-80 transition-opacity">
                <img src="/logos/ueni.jpg" alt="UENI Ltd" class="w-full h-full object-cover" />
              </a>
            </div>
            <div class="flex-1">
              <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-y-2 mb-2">
                <div>
                  <h3 class="font-bold text-lg text-slate-900 dark:text-slate-100 leading-snug">Front-End Team Lead</h3>
                  <p class="text-secondary dark:text-slate-400 text-sm mt-0.5">
                    <a href="https://ueni.com" target="_blank" class="hover:text-primary dark:hover:text-blue-400 transition-colors">UENI Ltd</a>
                  </p>
                </div>
                <div class="flex items-center gap-3">
                  <span class="text-sm text-secondary dark:text-slate-400 whitespace-nowrap">Mar 2018 - Feb 2019</span>
                </div>
              </div>
              <p class="text-xs text-secondary dark:text-slate-500 mb-3 font-medium uppercase tracking-wide">Prague</p>
              <div class="prose prose-md dark:prose-invert max-w-none text-slate-700 dark:text-slate-300">
                <p>Led a front-end team building a website creation platform for small businesses. Architecture, mentoring, and delivery.</p>
              </div>
            </div>
          </div>

          <!-- Node Vision -->
          <div class="flex flex-col sm:flex-row gap-5">
            <div class="shrink-0 w-12 h-12 rounded-lg overflow-hidden bg-slate-100 dark:bg-slate-800 shadow-sm mt-1 border border-slate-200 dark:border-slate-700">
              <a href="https://nodevision.com.au" target="_blank" class="block w-full h-full hover:opacity-80 transition-opacity">
                <img src="/logos/nodevision.jpg" alt="Node Vision" class="w-full h-full object-cover" />
              </a>
            </div>
            <div class="flex-1">
              <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-y-2 mb-2">
                <div>
                  <h3 class="font-bold text-lg text-slate-900 dark:text-slate-100 leading-snug">Architect & Co-founder</h3>
                  <p class="text-secondary dark:text-slate-400 text-sm mt-0.5">
                    <a href="https://nodevision.com.au" target="_blank" class="hover:text-primary dark:hover:text-blue-400 transition-colors">Node Vision</a>
                  </p>
                </div>
                <div class="flex items-center gap-3">
                  <span class="text-sm text-secondary dark:text-slate-400 whitespace-nowrap">Jul 2016 - Mar 2018</span>
                </div>
              </div>
              <p class="text-xs text-secondary dark:text-slate-500 mb-3 font-medium uppercase tracking-wide">Sydney</p>
              <div class="prose prose-md dark:prose-invert max-w-none text-slate-700 dark:text-slate-300">
                <p>Co-founded a tech company building web, mobile and AI applications for clients across Australia.</p>
              </div>
            </div>
          </div>

        </div>
      </div>

      <!-- EDUCATION -->
      <div>
        <h2 class="text-sm font-bold tracking-widest uppercase text-secondary dark:text-slate-500 mb-6 font-heading">Education</h2>
        <div class="space-y-8">
          
          <!-- JCU -->
          <div class="flex flex-col sm:flex-row gap-5">
            <div class="shrink-0 w-12 h-12 rounded-lg overflow-hidden bg-slate-100 dark:bg-slate-800 shadow-sm mt-1 border border-slate-200 dark:border-slate-700">
              <a href="https://www.jcu.edu.au/" target="_blank" class="block w-full h-full hover:opacity-80 transition-opacity">
                <img src="/logos/jcu.jpg" alt="James Cook University" class="w-full h-full object-cover" />
              </a>
            </div>
            <div class="flex-1">
              <div class="flex flex-col sm:flex-row sm:items-baseline justify-between gap-y-1 mb-1">
                <h3 class="font-bold text-lg text-slate-900 dark:text-slate-100 leading-snug">MSc Information Technology</h3>
                <span class="text-sm text-secondary dark:text-slate-400">2002 - 2003</span>
              </div>
              <p class="text-sm text-secondary dark:text-slate-400"><a href="https://www.jcu.edu.au/" target="_blank" class="hover:text-primary dark:hover:text-blue-400 transition-colors">James Cook University</a> &bull; Multimedia</p>
            </div>
          </div>

          <!-- University of Economics, Prague -->
          <div class="flex flex-col sm:flex-row gap-5">
            <div class="shrink-0 w-12 h-12 rounded-lg overflow-hidden bg-slate-100 dark:bg-slate-800 shadow-sm mt-1 border border-slate-200 dark:border-slate-700">
              <a href="https://www.vse.cz/english/" target="_blank" class="block w-full h-full hover:opacity-80 transition-opacity">
                <img src="/logos/vse.jpg" alt="University of Economics, Prague" class="w-full h-full object-cover" />
              </a>
            </div>
            <div class="flex-1">
              <div class="flex flex-col sm:flex-row sm:items-baseline justify-between gap-y-1 mb-1">
                <h3 class="font-bold text-lg text-slate-900 dark:text-slate-100 leading-snug">BSc Information Technology</h3>
                <span class="text-sm text-secondary dark:text-slate-400">1997 - 2001</span>
              </div>
              <p class="text-sm text-secondary dark:text-slate-400"><a href="https://www.vse.cz/english/" target="_blank" class="hover:text-primary dark:hover:text-blue-400 transition-colors">University of Economics, Prague</a> &bull; IT & Economics</p>
            </div>
          </div>

        </div>
      </div>

      <!-- SKILLS -->
      <div>
        <h2 class="text-sm font-bold tracking-widest uppercase text-secondary dark:text-slate-500 mb-6 font-heading">Skills</h2>
        <div class="flex flex-wrap gap-2.5">
          {
            ['Team Leadership', 'AI & Automation', 'System Architecture', 'Consumer Apps', 'Fintech & Payments', 'B2B SaaS', 'Product Strategy', 'Full-Stack Development', 'TypeScript'].map((skill) => (
              <span class="text-sm bg-slate-100 hover:bg-slate-200 dark:bg-slate-800 dark:hover:bg-slate-700 transition-colors text-slate-800 dark:text-slate-300 px-4 py-2 rounded-full font-medium shadow-sm border border-slate-200 dark:border-slate-700">
                {skill}
              </span>
            ))
          }
        </div>
      </div>

    </div>
  </section>
</Layout>
